string hex_to_color(string hex)
{
    // Remove "#" se existir e força 6 caracteres
    if(llGetSubString(hex, 0, 0) == "#")
    {
        hex = llGetSubString(hex, 1, -1);
    }

    // Se for curto demais, retorna branco como fallback
    if(llStringLength(hex) != 6)
    {
        return "<1.0, 1.0, 1.0>";
    }

    // Pega pares de caracteres
    string r_hex = llGetSubString(hex, 0, 1);
    string g_hex = llGetSubString(hex, 2, 3);
    string b_hex = llGetSubString(hex, 4, 5);

    // Converte para inteiros (0-255)
    integer r = (integer)("0x" + r_hex);
    integer g = (integer)("0x" + g_hex);
    integer b = (integer)("0x" + b_hex);

    // Normaliza para 0.0-1.0
    return (string)<(float)r / 255.0, (float)g / 255.0, (float)b / 255.0>; 
}
string color(string s) {
	integer i = llListFindList(color_list, [s]);
	if (i == -1) return "not found";
	else
		return llList2String(color_list,i+1);
}
integer SET_COLOR           = -204007;
default
{
	state_entry()
	{
		llOwnerSay(color("purple_500"));
	}
	link_message(integer sender_number, integer number, string message, key id)
	{
		
        if(number == SET_COLOR) {
            if(llSubStringIndex(message, "#") == 0) message = hex_to_color(message);
        else if (color(message) != "not found") message = color(message);
            llMessageLinked(LINK_SET, -SET_COLOR, message, "");
        }
	}
}